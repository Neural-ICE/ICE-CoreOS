+# Neural ICE: build the NVIDIA open GPU (r595) modules against the freshly built
+# base kernel and stage them UNSIGNED under the module tree. __modsign_install_post
+# signs them together with the in-tree modules using this build's ephemeral key.
+%{log_msg "Building NVIDIA open GPU modules against %{KVERREL}"}
+# Build in a subshell with RPM LDFLAGS cleared: those linker flags can interfere
+# with the out-of-tree module build (the standalone NVIDIA driver spec clears
+# them the same way before `make modules`).
+( unset LDFLAGS LDFLAGS_MODULE || : ; \
+  make -C %{_builddir}/nvidia-open-gpu-%{nvidia_open_ver} %{?_smp_mflags} modules \
+       SYSSRC="%{_builddir}/kernel-%{tarfile_release}/linux-%{KVERREL}" \
+       IGNORE_CC_MISMATCH=1 )
+mkdir -p $RPM_BUILD_ROOT/lib/modules/%{KVERREL}/extra/nvidia-open
+find %{_builddir}/nvidia-open-gpu-%{nvidia_open_ver} -name '*.ko' -exec \
+     install -m 0644 {} $RPM_BUILD_ROOT/lib/modules/%{KVERREL}/extra/nvidia-open/ \;
+echo "kernel.spec: staged NVIDIA .ko: $(find $RPM_BUILD_ROOT/lib/modules/%{KVERREL}/extra/nvidia-open -name '*.ko' 2>/dev/null | wc -l)"
 %endif
 
